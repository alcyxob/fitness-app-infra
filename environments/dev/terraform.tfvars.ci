aws_region            = "eu-west-1"
app_name              = "fitness-app"
environment           = "dev"
ecr_image_tag         = "latest"
s3_bucket_name_suffix = "videos"
lambda_memory_size    = 256
lambda_timeout        = 30
database_uri          = "mongodb+srv://ci-placeholder:placeholder@cluster.example.net/db"
database_name         = "fitness_app_ci"
jwt_secret            = "ci-placeholder-secret-value-minimum-32-chars-long!"
jwt_expiration        = "60m"
log_level             = "INFO"
log_retention_days    = 14
s3_region             = "eu-west-1"
s3_use_ssl            = "true"
cors_allowed_origins  = ["http://localhost:3000"]
apple_app_bundle_id   = "com.example.FitnessClient"
custom_domain_name    = ""
